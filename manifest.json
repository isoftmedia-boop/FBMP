{
  "manifest_version": 3,
  "name": "Fast4FBMP",
  "version": "2.0",
  "description": "Scrape, manage and relist your Facebook Marketplace published listings.",
  "permissions": ["activeTab","scripting","storage","cookies","notifications","alarms","sidePanel"],
  "host_permissions": ["https://www.facebook.com/*","https://tools.joinflyp.com/*"],
  "background": {"service_worker": "background.js"},
  "side_panel": {"default_path": "sidepanel/panel.html"},
  "action": {"default_title": "Fast4FBMP", "default_icon": {"128": "images/icon128.png"}},
  "icons": {"16": "images/icon16.png","48": "images/icon48.png","128": "images/icon128.png"},
  "content_scripts": [{
    "matches": ["https://www.facebook.com/marketplace/*","https://tools.joinflyp.com/*"],
    "js": ["lib/fs_local.js","content/photo_inject.js","content/scrape_published.js"],
    "run_at": "document_idle",
    "all_frames": false
  }]
}
